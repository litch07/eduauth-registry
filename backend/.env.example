# ==========================================
# APPLICATION CONFIGURATION
# ==========================================

# The name of your application. Used in emails, UI headers, etc.
APP_NAME="EduAuth Registry"

# The environment your application is running in (local, production, staging).
# CRITICAL: Always set to 'production' on live servers.
APP_ENV=local

# The application encryption key. Used to encrypt sessions and other sensitive data.
# Generate via: php artisan key:generate
APP_KEY=

# Whether the app should display detailed error messages on exceptions.
# CRITICAL: Always set to 'false' in production to prevent leaking sensitive info.
APP_DEBUG=true

# The base URL of your application backend. Must not have a trailing slash.
APP_URL=http://localhost:8000

# Application locale settings
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Determines how the "down" maintenance mode state is tracked (file or database)
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

# Number of bcrypt rounds for password hashing. Default 12 is recommended.
BCRYPT_ROUNDS=12

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# Database connection details. For production, ensure DB_PASSWORD is secure.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eduauth_registry
DB_USERNAME=root
DB_PASSWORD=

# ==========================================
# SESSION & CACHE CONFIGURATION
# ==========================================

# How sessions are stored (cookie, database, file, redis, memcached).
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# How caches are stored. 'database' is good for small deployments; use 'redis' for scaling.
CACHE_STORE=database
CACHE_PREFIX=

# ==========================================
# QUEUE & FILE STORAGE
# ==========================================

# Determines where uploaded files are stored (local, s3).
FILESYSTEM_DISK=local

# Connection used for background jobs (database, redis, sqs).
QUEUE_CONNECTION=database

# ==========================================
# REDIS CONFIGURATION (Optional)
# ==========================================
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================
# MAIL/SMTP CONFIGURATION
# ==========================================
# Configuration for sending emails (e.g., verification, password resets).
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@eduauth.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# FRONTEND / SANCTUM CONFIGURATION
# ==========================================

# The exact URL of the React frontend. Crucial for CORS and email links.
FRONTEND_URL=http://localhost:5173

# Comma-separated list of domains that are allowed to make stateful requests (cookies/CSRF) to the API.
# Note: Since this project relies on JWT tokens rather than stateful cookies for API auth,
# this is mostly for potential future Sanctum SPA authentication fallback.
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# Vite variable for React
VITE_APP_NAME="${APP_NAME}"
